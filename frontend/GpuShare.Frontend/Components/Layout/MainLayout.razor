@inherits LayoutComponentBase
@using GpuShare.Frontend.Services
@using GpuShare.Frontend.Models
@using GpuShare.Frontend.State
@using MudBlazor
@inject AuthModalService AuthModal
@inject IAuthService AuthService
@inject AuthState AuthState

<MudThemeProvider Theme="@GpuTheme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<div class="page">
    <header class="top-nav">
        <div class="nav-container">
            <div class="brand">GPUSHARE</div>

            <nav class="nav-links">
                <NavLink href="/">Search</NavLink>
                @if (AuthState.IsAuthenticated)
                {
                    <NavLink href="/profile">@AuthState.User!.Username</NavLink>
                    <button class="login-btn" @onclick="Logout">Logout</button>
                }
                else
                {
                    <button class="login-btn" @onclick="OpenLogin">Login</button>
                }
            </nav>
        </div>
    </header>
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<LoginModal IsVisible="@AuthModal.IsOpen" OnClose="CloseModal" />

@code {
    protected override void OnInitialized()
    {
        AuthModal.OnChange += StateHasChanged;
    }

    private void OpenLogin() 
    { 
        AuthModal.Open();
        Console.WriteLine("Login modal opened");
    }

    private async Task Logout() 
    {
        await AuthService.LogoutAsync();
        Console.WriteLine("User logged out");
    }

    private void CloseModal() => AuthModal.Close();

    private MudTheme GpuTheme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#4C6EB2",
            Secondary = "#7c4dff",
            Success = "#4caf50",
            Info = "#2196f3",
            Warning = "#ff9800",
            Error = "#B63939",
            Background = "#f5f7fb",
            Surface = "#ffffff"
        }
    };
}
