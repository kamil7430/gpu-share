@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider Theme="@GpuTheme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<div class="page">
    <header class="top-nav">
        <div class="nav-container">
            <div class="brand">GPUSHARE</div>

            <TopNav />
        </div>
    </header>
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>



@code {
    private MudTheme GpuTheme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#4C6EB2",
            Secondary = "#7c4dff",
            Success = "#4caf50",
            Info = "#2196f3",
            Warning = "#ff9800",
            Error = "#B63939",
            Background = "#f5f7fb",
            Surface = "#ffffff"
        }
    };
}
