@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@inject IAuthState AuthState
@inject IOrderService OrderService
@inject IDeviceService DeviceService

@page "/order/{OrderId:int}"
@attribute [Authorize]

<div class="cards-container">
    <div class="page-top" style="margin-bottom: 8px;">
        <NavLink href=@_profileLink class="back-link">&lt; Back to Profile</NavLink>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="card">
                <!-- Header -->
                <div class="page-header">
                    <div>
                        <div class="page-subtitle">Order #@OrderId</div>
                        <h1 style="margin: 0;">@_gpu.Model • @_gpu.Name</h1>
                    </div>

                    <MudChip T="string" Color="@GetChipColor(_order.Status)" Variant="Variant.Filled">
                        @GetChipContent(_order.Status)
                    </MudChip>
                </div>

                <!-- Live Stats -->
                <DeviceStatsCard />

                <!-- Actions -->
                <div class="flex-row" style="justify-content: space-between;">
                    <button class="btn-danger" @onclick='OpenEndModal'>
                        <MudIcon Icon="@Icons.Material.Filled.StopCircle" Style="margin-right: 4px;" />End Session
                    </button>

                    @if (CanOpenDispute)
                    {
                        <a class="dispute-link" href="@($"/orders/{OrderId}/dispute")">Report an Issue</a>
                    }
                </div>
            </div>

            <!-- Telemetry -->
            <OrderTelemetryCard />

            <!-- Connection -->
            <ConnectionCard />
        </Authorized>
        <NotAuthorized>
            <div class="card">
                <h3>You are not authorized to view this order.</h3>
                <p>Please log in to access your orders and sessions.</p>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

<!-- End Session Modal -->
<EndSessionModal ShowEndModal="@_showEndModal" />


@code {

    [Parameter] public int OrderId { get; set; }

    private DateTime _startTime = DateTime.UtcNow.AddMinutes(-12);
    private bool _showEndModal;
    private string _profileLink;
    private Order _order;
    private Device _gpu;
    private User _user;

    private bool CanOpenDispute => DateTime.UtcNow - _startTime > TimeSpan.FromMinutes(5);

    protected override async Task OnParametersSetAsync()
    {
        _order = await OrderService.GetOrderAsync(OrderId);
        _gpu = await DeviceService.GetDeviceAsync(_order.DeviceId);
        _user = AuthState?.User;
        _profileLink = $"/profile/{_user?.Username}";
    }

    private string GetChipContent(OrderStatus status) => status switch
    {
        OrderStatus.WaitingForStart => "Waiting for start",
        OrderStatus.Running => "Running",
        OrderStatus.Completed => "Completed",
        OrderStatus.Suspended => "Suspended",
        OrderStatus.Failure => "Failure",
        _ => "Unknown status"
    };

    private Color GetChipColor(OrderStatus status) => status switch
    {
        OrderStatus.WaitingForStart => Color.Info,
        OrderStatus.Running => Color.Success,
        OrderStatus.Completed => Color.Success,
        OrderStatus.Suspended => Color.Warning,
        OrderStatus.Failure => Color.Error,
        _ => Color.Error
    };

    private void OpenEndModal()
    {
        _showEndModal = true;
        Console.WriteLine($"Open End Session Modal: _showEndModal={_showEndModal}");
    }
}