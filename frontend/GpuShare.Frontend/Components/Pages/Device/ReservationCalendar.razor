@inject IOrderService OrderService
@using GpuShare.Frontend.Models.Dtos

<div class="card">
            <div class="calendar-toolbar">
                <button Class="btn-secondary" @onclick="PreviousWeek">
                    Previous
                </button>

                <MudText Typo="Typo.h6">
                    @(WeekStart.ToString("dd.MM.yyyy")) - @(WeekStart.AddDays(6).ToString("dd.MM.yyyy"))
                </MudText>

                <button Class="btn-secondary" @onclick="NextWeek">
                    Next
                </button>
            </div>

            <div class="week-calendar">
                <div class="calendar-header"></div>

                @foreach (var day in WeekDays)
                {
                    <div class="calendar-header-cell">
                        <div>@day.ToString("ddd")</div>
                        <div class="date">@day.Day</div>
                    </div>
                }

                @foreach (var hour in Hours)
                {
                    <div class="time-label">
                        @($"{hour:00}:00")
                    </div>

                    @foreach (var day in WeekDays)
                    {
                        <div class="calendar-cell">
                            @foreach (var order in GetOrdersForSlot(day, hour))
                            {
                                <div class="reservation-block" style="@GetOrderStyle(order)" title="@order.OwnerUsername">
                                    <div class="reservation-title">
                                        @order.OwnerUsername
                                    </div>

                                    <div class="reservation-time">
                                        @order.StartDate?.ToString("HH:mm") - @order.EndDate?.ToString("HH:mm")
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

            <div class="calendar-legend">

                <div class="legend-item">
                    <div class="legend-color reserved"></div>
                    <span>Reserved</span>
                </div>

                <div class="legend-item">
                    <div class="legend-color in-use"></div>
                    <span>In Use</span>
                </div>

                <div class="legend-item">
                    <div class="legend-color completed"></div>
                    <span>Completed</span>
                </div>

                <div class="legend-item">
                    <div class="legend-color available"></div>
                    <span>Available</span>
                </div>

            </div>
        </div>

@code {
    [Parameter] public int DeviceId { get; set; }

    private DateTime WeekStart = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + 1);

    private List<int> Hours = Enumerable.Range(0, 24).ToList();

    private List<DateTime> WeekDays => Enumerable.Range(0, 7).Select(i => WeekStart.AddDays(i)) .ToList();

    private List<Order> orders = new();

    private const int DayHeightPx = 1440; // or scaled version
    private const double PxPerMinute = 80.0/60.0; // tweak this

    // public class Reservation
    // {
    //     public string Title { get; set; } = "";
    //     public string Status { get; set; } = "";

    //     public DateTime Start { get; set; }
    //     public DateTime End { get; set; }
    // }

    protected override async Task OnInitializedAsync()
    {
        await LoadOrdersForWeek();
    }

    private async Task LoadOrdersForWeek()
    {
        // In a real implementation, you'd fetch orders from the backend based on the week range
        // For example:
        // orders = await OrderService.GetOrdersForDeviceAndWeek(deviceId, WeekStart);
        var pagedResult = await OrderService.ListOrdersAsync(new OrderQueryParams
        {
            DeviceId = 1, // replace with actual device ID
            StartDate = WeekStart,
            EndDate = WeekStart.AddDays(7)
        });
        orders = pagedResult.Items.ToList();
    }

    // ===== HELPERS =====
    private IEnumerable<Order> GetOrdersForSlot(DateTime day, int hour)
    {

        return orders.Where(r =>
            r.StartDate != null && r.StartDate?.Date == day.Date &&
            r.StartDate?.Hour == hour);
    }

    private string GetOrderStyle(Order r)
{
    var startMinutes = r.StartDate?.Minute;
    var durationMinutes = (r.EndDate - r.StartDate)?.TotalMinutes;
    
    var top = startMinutes * PxPerMinute + 4; // +4 for some padding from the top of the cell
    var height = durationMinutes * PxPerMinute - 8; // -8 for some padding from the bottom of the cell

    return $@"
        position: absolute;
        top: {top}px;
        height: {height}px; 
        left: 4px;
        right: 4px;
        background: {GetColor(r.Status)};
    ";
}

    private string GetColor(string status) => status switch
    {
        "Reserved" => "#ff9800",
        "In Use" => "#f44336",
        "Completed" => "#2196f3",
        _ => "#4caf50"
    };

    // =========================
    // NAVIGATION
    // =========================

    private async Task NextWeek()
    {
        WeekStart = WeekStart.AddDays(7);
        await LoadOrdersForWeek();
    }

    private async Task PreviousWeek()
    {
        WeekStart = WeekStart.AddDays(-7);
        await LoadOrdersForWeek();
    }
}