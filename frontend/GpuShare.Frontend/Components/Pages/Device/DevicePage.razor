@page "/device/{ModeString}/{Id:int}"
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor.Charts
@using GpuShare.Frontend.Models
@using GpuShare.Frontend.State
@inject IAuthState AuthState
@inject NavigationManager Navigation

@* what happens when the reserved time run out but the job is not finished 

*@

<div class="cards-container">
    <div class="page-header" style="margin-bottom: 8px;">
        <NavLink href="/profile" class="back-link">&lt; Back to Profile</NavLink>
    </div>

    <!-- Info card -->
    @if (Mode != DevicePageMode.Add) {
        <DeviceInfoCard gpu="@gpu" Username="@Username"></DeviceInfoCard>
    }

    
    <!--  Edit form -->
    @if ((Mode == DevicePageMode.Edit || Mode == DevicePageMode.Add))
    {
        <AuthorizeView>
            <Authorized>
                <EditDeviceForm gpu="@gpu" Mode="@Mode"></EditDeviceForm>
            </Authorized>
        </AuthorizeView>
    }

    @if (Mode != DevicePageMode.Add) {
        <AuthorizeView>
            <Authorized>
                <!-- Telemetry -->
                <TelemetryCard></TelemetryCard>

                <!-- Reservation Calendar -->
                <ReservationCalendar></ReservationCalendar>
            </Authorized>
            <NotAuthorized>
                <!-- Opinions -->
                <div class="card">
                    <h4 style="margin-bottom: 16px;">Owner rating: 4.5 </h4>
                    <h4 style="margin-bottom: 24px;">Opinions about this gpu:</h4>
                    <OpinionsList></OpinionsList>
                </div>

                <!-- Order form -->
                <DeviceOrderForm></DeviceOrderForm>
            </NotAuthorized>
        </AuthorizeView>
        
    }

</div>

@code {
    [Parameter] public string ModeString { get; set; } = "view"; // "view", "edit", "add"
    [Parameter] public int Id { get; set; }

    private DevicePageMode Mode => Enum.TryParse<DevicePageMode>(ModeString, ignoreCase: true, out var mode)
            ? mode : DevicePageMode.View;
    private GpuShare.Frontend.Models.Device gpu = new();
    private bool isAuthorized = true;
    private string Username = "user1";

    protected override void OnInitialized()
    {
        gpu = new Device
        {
            Name = "Workstation-Alpha",
            Model = "RTX 4090",
            VramMb = 24576,
            CudaCores = 16384,
            DriverVersion = "535.xx",
            Frameworks = new() { "CUDA", "TensorRT" },
            IsAvailable = true
        };
    }

    protected override void OnParametersSet()
    {
        /*if (Id.HasValue)
        {
            // Mock: Load existing device data
            gpu = new Device { Name = "Workstation-Alpha", Model = "RTX 4090", VramMb = 24576, CudaCores = 16384 };
            }*/
    }

    
}