@inject IAuthState AuthState
@inject IReviewService ReviewService

<div class="profile-card card">
    <div class="flex-row" style="justify-content: space-between; align-items: flex-start;">
        <div class="user-info">
            <h3 style="font-weight: bold;">@Username</h3>
            
            <div class="stats-row">
                <div class="stat-item">
                    <span class="stat-label">Rating</span>
                    <span class="stat-value">
                        @(_userRating?.AverageRating ?? 0)/5 <span class="rating-count">(@(_userRating?.RatingCount ?? 0))</span>
                    </span>
                </div>
            </div>
        </div>

        @if (AuthState.IsAuthenticated && Username == AuthState.User!.Username)
        {
            <button class="btn-secondary" @onclick="ChangePassword">
                Change Password
            </button>
        }
    </div>
</div>

@if (AuthState.IsAuthenticated)
{
    <ChangePasswordModal IsVisible="@_showChangePasswordModal" OnClose="@(() => _showChangePasswordModal = false)" />
}

@code {
    [Parameter] public string? Username { get; set; }

    private UserRatingDto? _userRating { get; set; }
    private bool _showChangePasswordModal = false;

    protected override async Task OnParametersSetAsync()
    {
        if (Username != null)
        {
            _userRating = await ReviewService.GetUserRatingAsync(Username);
        }
    }

    private void ChangePassword()
    {
        _showChangePasswordModal = true;
    }
}