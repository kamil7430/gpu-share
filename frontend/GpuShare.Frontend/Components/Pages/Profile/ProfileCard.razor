<div class="profile-card card">
    <div class="flex-row" style="justify-content: space-between; align-items: flex-start;">
        <div class="user-info">
            <h3 style="font-weight: bold;">My Username/Email</h3>
            
            <div class="stats-row">
                @* <div class="stat-item">
                    <span class="stat-label">Balance</span>
                    <span class="stat-value">120$</span>
                </div> *@
                <div class="stat-item">
                    <span class="stat-label">Rating</span>
                    <span class="stat-value">
                        4.56/5 <span class="rating-count">(21)</span>
                    </span>
                </div>
            </div>
        </div>

        @if (string.IsNullOrEmpty(Username))
        {
            <button class="btn-secondary" @onclick="ChangePassword">
                Change Password
            </button>
        }
    </div>
</div>

@if (string.IsNullOrEmpty(Username))
{
    <ChangePasswordModal IsVisible="@showChangePasswordModal" OnClose="@(() => showChangePasswordModal = false)" />
}

@code {
    [Parameter] public string? Username { get; set; }
    private bool showChangePasswordModal = false;

    private void ChangePassword()
    {
        showChangePasswordModal = true;
    }
}