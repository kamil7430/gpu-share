@if (IsVisible)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-dialog">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Change Password</h3>
                <button class="btn-close" @onclick="CloseModal">&times;</button>
            </div>

            <div class="modal-body">
                <EditForm Model="changePasswordModel" OnValidSubmit="HandleChangePassword">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <input name="oldPassword" autocomplete="current-password" type="password" placeholder="Old Password" @bind-value="changePasswordModel.OldPassword" />
                        <input name="newPassword" autocomplete="new-password" type="password" placeholder="New Password" @bind-value="changePasswordModel.NewPassword" />
                        <input name="confirmPassword" autocomplete="new-password" type="password" placeholder="Confirm Password" @bind-value="changePasswordModel.ConfirmPassword" />
                        <button class="action-btn btn-primary" type="submit">Change Password</button>
                    </EditForm>
            </div>
        </div>
        </div>
    </div>
}

@code {
    private ChangePasswordModel changePasswordModel = new ChangePasswordModel();

    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool ShowModal = false;

    private async Task CloseModal()
    {
        await OnClose.InvokeAsync();
    }

    private void HandleChangePassword()
    {
        // This code runs when the user clicks 'Change Password' or hits 'Enter'
        Console.WriteLine($"Changing password for user with old password {changePasswordModel.OldPassword}");
    }

    public class ChangePasswordModel
    {
        public string OldPassword { get; set; } = "";
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}