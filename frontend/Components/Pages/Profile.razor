@page "/profile"
@page "/profile/{Username}"

@* 
Project decisions:
- is the timeframe of the order fixed? if not then when and how the user can change/cancel the order?
- does the owner have to accept the order or is it automatically accepted? 
- maybe a calendar for every gpu when ordering?
*@

<div class="profile-page cards-container">
<div class="profile-card card">
    <div class="header-main-row">
        <div class="user-info">
            <h3>My Username/Email</h3>
            
            <div class="stats-row">
                <div class="stat-item">
                    <span class="stat-label">Balance</span>
                    <span class="stat-value">120$</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Rating</span>
                    <span class="stat-value">
                        4.56/5 <span class="rating-count">(21)</span>
                    </span>
                </div>
            </div>
        </div>

        @if (string.IsNullOrEmpty(Username))
        {
            <button class="btn-change-password btn-secondary" @onclick="ChangePassword">
                Change Password
            </button>
        }
    </div>
</div>

<WalletCard></WalletCard>

<div class="card">
    <div class="header-main-row">
        @if (string.IsNullOrEmpty(Username))
        {
            <h3>My GPUs</h3>
            <button class="btn-add-device btn-primary" @onclick="AddDevice">Add GPU</button>
        }
        else
        {
            <h3>@Username's GPUs</h3>
        }
    </div>

    <GpuCard authorized="@authorized" />
</div>

@if (string.IsNullOrEmpty(Username))
{
<div class="card">
    <div class="header-main-row">
        <h3>My Orders</h3>
    </div>

    <OrderTable />
</div>
}

<div class="card">
    <div class="header-main-row">
        <h3>Opinions</h3>
    </div>

    <OpinionsCard />
</div>

</div>

@if (string.IsNullOrEmpty(Username))
{
    <ChangePasswordModal IsVisible="@showChangePasswordModal" OnClose="@(() => showChangePasswordModal = false)" />
}

@if(showRemoveModal){

<div class="modal-backdrop" @onclick="CloseModal">
    <div class="modal-dialog">
    <div class="modal-content" @onclick:stopPropagation="true">
        <div class="remove-device-modal">

            <MudIcon Icon="@Icons.Material.Filled.WarningAmber"
                     Color="Color.Error"
                     Size="Size.Large"
                     Class="mb-4" />

            <MudText Typo="Typo.h5" GutterBottom="true">
                Remove Device
            </MudText>

            <MudText Typo="Typo.body1" Class="mb-4">

                Are you sure you want to permanently remove
                <b>@gpu.Name</b> from your device fleet?

            </MudText>

            <MudAlert Severity="Severity.Warning"
                      Dense="true"
                      Variant="Variant.Outlined"
                      Class="mb-4">

                This action cannot be undone.

                <ul class="modal-warning-list">
                    <li>All future reservations will be cancelled</li>
                    <li>Users will lose access to this GPU</li>
                    <li>Monitoring statistics and uptime history may be deleted</li>
                    <li>Active workloads may be interrupted</li>
                </ul>

            </MudAlert>

            @* @if (gpu.HasActiveReservations)
            {
                
            } *@

            <MudAlert Severity="Severity.Error"
                          Dense="true"
                          Variant="Variant.Filled">

                    This device currently has active reservations.
                    Removing it may affect running workloads.

                </MudAlert>

        </div>

        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   OnClick="Cancel">

            Cancel

        </MudButton>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.Delete"
                   OnClick="ConfirmRemove">

            Remove Device

        </MudButton>
    </div>
    </div>
</div>
}

@code {
