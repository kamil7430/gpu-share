    private bool authorized = false;
    private bool showChangePasswordModal = false;
    private List<Gpu> devices = [];

    private Gpu gpu;
    private bool showRemoveModal = false;

    protected override void OnInitialized()
    {
        // mock data
        devices = Enumerable.Range(1, 10).Select(i => new Gpu
        {
            Id = i,
            Name = $"GPU {i}",
            IsAvailable = i % 2 == 0,
            VramMb = 24567,
            CudaCores = 16384,
            DriverVersion = "535.104",
            Frameworks = ["PyTorch", "Tensorflow"],
            PricePerHour = 5
        }).ToList();

        gpu = devices[0];
    }
    
    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(Username))
        {
            // Logic: Load the current logged-in user's data
            authorized = true; // Mocked authorization, replace with actual auth logic
        }
        else
        {
            // Logic: Load data for the specific "Username"
            authorized = false; // Mocked authorization, replace with actual auth logic
        }
    }

    private void ChangePassword()
    {
        showChangePasswordModal = true;
    }

    private void AddDevice()
    {
        
    }

    private void Cancel() {

    }

    private void ConfirmRemove() {

    } 

    private async Task CloseModal()
    {
        await OnClose.InvokeAsync();
    }

    [Parameter] public EventCallback OnClose { get; set; }
