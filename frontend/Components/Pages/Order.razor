@page "/order/{OrderId:int}"

@using MudBlazor
@using MudBlazor.Charts
@implements IDisposable
@inject IJSRuntime JS

<div class="cards-container">
    <div class="page-top" style="margin-bottom: 8px;">
        <NavLink href="/profile" class="back-link">&lt; Back to Profile</NavLink>
    </div>

    <div class="card">
        <!-- Header -->
        <div class="page-header">
            <div>
                <div class="page-subtitle">Order #@OrderId</div>
                <h1 style="margin: 0;">RTX 4090 • Workstation Alpha</h1>
            </div>

            <MudChip T="string" Color="Color.Success" Variant="Variant.Filled">
                Active Session
            </MudChip>
        </div>

        <!-- Live Stats -->
        <div class="stats-grid">
            <!-- Countdown -->
            <div class="spec-box">
                <div class="label">Remaining Time</div>
                <div class="value">@RemainingTime.ToString(@"hh\:mm\:ss")</div>
                <div class="hint">Session ends at @EndTime.ToString("HH:mm:ss")</div>
            </div>

            <!-- Cost -->
            <div class="spec-box">
                <div class="label">Live Cost</div>
                <div class="value">$@CurrentCost.ToString("0.00")</div>
                <div class="hint">$2.40 / hour</div>
            </div>

            <!-- Heartbeat -->
            <div class="spec-box">
                <div class="label">Agent Status</div>
                <div class="heartbeat-row">
                    <div class="heartbeat-dot"></div>
                    <span class="value">Connected</span>
                </div>
                <div class="hint">Last heartbeat 4s ago</div>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex-row" style="justify-content: space-between;">
            <button class="btn-danger" @onclick='() => ShowEndModal = true'>
                <MudIcon Icon="@Icons.Material.Filled.StopCircle" Style="margin-right: 4px;" />End Session
            </button>

            @if (CanOpenDispute)
            {
                <a class="dispute-link" href="@($"/orders/{OrderId}/dispute")">Report an Issue</a>
            }
        </div>
    </div>

    <!-- Telemetry -->
    <div class="card">
        <div class="telemetry-header">
            <h3>Live GPU Telemetry</h3>
            <MudChip T="string" Color="Color.Info"Variant="Variant.Outlined">SSE Stream</MudChip>
        </div>

        <MudChart T="double" ChartType="ChartType.Line" ChartLabels="@ChartLabels" ChartSeries="@ChartSeries" Width="100%" Height="360px" MatchBoundsToSize=true ChartOptions="@options"/>
    </div>

    <!-- Connection -->
    <div class="card">
        <h3> Connection Details</h3>

        <div class="stats-grid mt-2">
            <div class="spec-box">
                <div class="label">Host</div>
                <div class="value" style="height: 100%; font-size: large;">gpu-12.gpushare.io</div>
            </div>

            <div class="spec-box">
                <div class="label">Port</div>
                <div class="value">443</div>
            </div>

            <div class="spec-box">
                <div class="label">Protocol</div>
                <div class="value">WSS</div>
            </div>

        </div>

        <div class="connection-command">
            <code>wss://gpu-12.gpushare.io/connect/session_x82A</code>

            <button class="btn-dark" @onclick='CopyConnectionString'>
                <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Style="width: 16px; height: 16px;" />
            </button>
        </div>
    </div>

</div>

<!-- End Session Modal -->

@if (ShowEndModal)
{
    <BaseModal IsVisible="true" Title="End Session" OnClose="CloseEndModal" SizeClass="small">
        <ChildContent>
            <div class="end-session-modal">
                @* <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Color="Color.Warning" Size="Size.Large" /> *@
                Are you sure you want to terminate this GPU session?
                <div class="modal-warning">
                    Running workloads may be interrupted immediately.
                </div>
            </div>
        </ChildContent>
        <FooterContent>
            <button class="btn-cancel" @onclick="CloseEndModal">
                Cancel
            </button>

            <button class="btn-danger" @onclick="EndSession">
                End Session
            </button>
        </FooterContent>
    </BaseModal>
}

@code {

    [Parameter]
    public int OrderId { get; set; }

    private System.Timers.Timer? Timer;

    private DateTime StartTime = DateTime.UtcNow.AddMinutes(-12);

    private DateTime EndTime = DateTime.UtcNow.AddHours(2);

    private decimal HourlyRate = 2.40m;

    private decimal CurrentCost;

    private TimeSpan RemainingTime;

    private bool ShowEndModal;

    private bool CanOpenDispute =>
        DateTime.UtcNow - StartTime > TimeSpan.FromMinutes(5);

    private string[] ChartLabels =
    {
        "0m", "5m", "10m", "15m", "20m", "25m", "30m"
    };

    private List<ChartSeries<double>> ChartSeries = new()
    {
        new ChartSeries<double> { Name = "GPU Usage", Data = new double[] { 20, 45, 60, 88, 72, 64, 58 } },
        new ChartSeries<double> { Name = "Memory Usage", Data = new double[] { 15, 30, 52, 70, 68, 60, 55 } },
        new ChartSeries<double> { Name = "Temperature", Data = new double[] { 48, 55, 60, 78, 81, 75, 71 } }
    };

    private LineChartOptions options = new(){};

    protected override void OnInitialized()
    {
        options.SeriesDisplayOverrides = new Dictionary<IChartSeries, SeriesDisplayOverride>()
        {
            { ChartSeries[0], new SeriesDisplayOverride(){
                LineDisplayType = LineDisplayType.Area,
            } },
            { ChartSeries[1], new SeriesDisplayOverride(){
                LineDisplayType = LineDisplayType.Area,
            } },
            { ChartSeries[2], new SeriesDisplayOverride(){
                LineDisplayType = LineDisplayType.Area,
            } }
        };
        options.ShowDataMarkers = true;

        UpdateLiveMetrics();

        Timer = new System.Timers.Timer(1000);

        Timer.Elapsed += (_, _) =>
        {
            InvokeAsync(() =>
            {
                UpdateLiveMetrics();

                StateHasChanged();
            });
        };

        Timer.Start();
    }

    private void UpdateLiveMetrics()
    {
        RemainingTime = EndTime - DateTime.UtcNow;

        if (RemainingTime < TimeSpan.Zero)
        {
            RemainingTime = TimeSpan.Zero;
        }

        var elapsedHours =
            (decimal)(DateTime.UtcNow - StartTime).TotalHours;

        CurrentCost = elapsedHours * HourlyRate;
    }

    private async Task CopyConnectionString()
    {
        await JS.InvokeVoidAsync(
            "navigator.clipboard.writeText",
            "wss://gpu-12.gpushare.io/connect/session_x82A");
    }

    private void CloseEndModal()
    {
        ShowEndModal = false;
    }

    private void EndSession()
    {
        Console.WriteLine("Session terminated");

        ShowEndModal = false;
    }

    public void Dispose()
    {
        Timer?.Dispose();
    }
}