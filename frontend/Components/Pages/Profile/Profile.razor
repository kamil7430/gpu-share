@page "/profile"
@page "/profile/{Username}"

@* 
Project decisions:
- is the timeframe of the order fixed? if not then when and how the user can change/cancel the order?
- does the owner have to accept the order or is it automatically accepted? 
- maybe a calendar for every gpu when ordering?
*@

<div class="profile-page cards-container">

    <!-- Profile Info -->
    <ProfileCard Username="@Username" />

    <!-- Wallet -->
    <WalletCard />

    <!-- GPUs -->
    <div class="card">
        <div class="flex-row" style="justify-content: space-between;">
            @if (string.IsNullOrEmpty(Username))
            {
                <h3>My GPUs</h3>
                <button class="btn-add-device btn-primary" @onclick="AddDevice">Add GPU</button>
            }
            else
            {
                <h3>@Username's GPUs</h3>
            }
        </div>

        <GpuList authorized="@authorized" />
    </div>

    <!-- Orders -->
    @if (string.IsNullOrEmpty(Username))
    {
        <div class="card">
            <div class="header-main-row">
                <h3>My Orders</h3>
            </div>

            <OrderTable />
        </div>
    }

    <!-- Opinions -->
    <div class="card">
        <div class="header-main-row">
            <h3>Opinions</h3>
        </div>

        <OpinionsList />
    </div>

</div>

@code {
    [Parameter] public string? Username { get; set; }
    private bool authorized = false;
    private List<Gpu> devices = [];

    private Gpu gpu;
    private bool showRemoveModal = false;

    protected override void OnInitialized()
    {
        // mock data
        devices = Enumerable.Range(1, 10).Select(i => new Gpu
        {
            Id = i,
            Name = $"GPU {i}",
            IsAvailable = i % 2 == 0,
            VramMb = 24567,
            CudaCores = 16384,
            DriverVersion = "535.104",
            Frameworks = ["PyTorch", "Tensorflow"],
            PricePerHour = 5
        }).ToList();

        gpu = devices[0];
    }
    
    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(Username))
        {
            // Logic: Load the current logged-in user's data
            authorized = true; // Mocked authorization, replace with actual auth logic
        }
        else
        {
            // Logic: Load data for the specific "Username"
            authorized = false; // Mocked authorization, replace with actual auth logic
        }
    }

