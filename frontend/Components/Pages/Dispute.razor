@page "/orders/{OrderId:int}/dispute"

@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations
@using MudBlazor

<div class="cards-container">
    <div class="page-top" style="margin-bottom: 8px;">
        <NavLink href="/profile" class="back-link">&lt; Back to Order</NavLink>
    </div>

    <div class="card">
    <div class="page-header">
        <div>
            <div class="page-subtitle">Order #@OrderId</div>
            <h1 style="margin: 0;">Report a Dispute</h1>
        </div>

        <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled">
            Under Review
        </MudChip>
    </div>

    <EditForm Model="Model" OnValidSubmit="SubmitDispute">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <!-- Rental Reference -->
        <div class="form-card">
            <h4>Rental Reference</h4>

            <div class="spec-grid">
                <div class="spec-box">
                    <div class="label">Order ID</div>
                    <div class="value">#@OrderId</div>
                </div>

                <div class="spec-box">
                    <div class="label">Device</div>
                    <div class="value">RTX 4090 • Workstation Alpha</div>
                </div>

                <div class="spec-box">
                    <div class="label">Owner</div>
                    <div class="value">gpu_master_77</div>
                </div>

                <div class="spec-box">
                    <div class="label">Rental Period</div>
                    <div class="value">2026-05-18 12:00 → 2026-05-18 18:00</div>
                </div>
            </div>
        </div>

        <!-- Reason -->
        <div class="form-card">
            <h4>Dispute Reason</h4>
            <MudRadioGroup T="string" @bind-Value="Model.Reason" Class="radio-column">
                <MudRadio Color="Color.Primary" T="string" Value='"Hardware mismatch"' Style="width: 100%;">
                    Hardware does not match listing
                </MudRadio>
                <MudRadio Color="Color.Primary" T="string" Value='"Hardware failure"' Style="width: 100%;">
                    GPU failure / instability
                </MudRadio>
                <MudRadio Color="Color.Primary" T="string" Value='"Billing issue"' Style="width: 100%;">
                    Billing or overcharge issue
                </MudRadio>
                <MudRadio Color="Color.Primary" T="string" Value='"Other"' Style="width: 100%;">
                    Other
                </MudRadio>
            </MudRadioGroup>
        </div>

        <!-- Details -->
        <div class="form-card">
            <h4>Problem Details</h4>
            <MudTextField T="string" @bind-Value="Model.Details" Variant="Variant.Outlined" Lines="6" Counter="5000" Immediate="true" Placeholder="Describe the issue in detail..." HelperText="Minimum 50 characters required." Class="details-input" />
        </div>

        <!-- Evidence Upload -->
        <div class="form-card">
            <h4>Evidence Upload</h4>

            <div class="upload-hint">
                Upload screenshots, logs, or other evidence.
                Maximum 3 files, 5MB each.
            </div>
            
            @* <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="@HandleFilesChanged" MaximumFileCount="3">
                <ButtonTemplate>
                    <MudButton HtmlTag="label"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.UploadFile"
                               for="@context">
                        Upload Evidence
                    </MudButton>
                </ButtonTemplate>
            </MudFileUpload> *@
            <MudFileUpload T="IReadOnlyList<IBrowserFile>" DragAndDrop="true" FilesChanged="HandleFilesChanged" MaximumFileCount="3" Accept=".pdf,.png,.jpg,.jpeg" Class="mt-2">
                <SelectedTemplate Context="another_name"/>
            </MudFileUpload>

            @if (UploadedFiles.Any())
            {
                <div class="uploaded-files">

                    @foreach (var file in UploadedFiles)
                    {
                        <div class="uploaded-file">
                            <div class="file-info">
                                <MudIcon Icon="@Icons.Material.Filled.Description"
                                         Size="Size.Small" />
                                <span>@file.Name</span>
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => RemoveFile(file))" />
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Submit -->
        <div class="submit-row">
            <button class="btn-danger" disabled="@(!CanSubmit)">
                Submit dispute
            </button>
        </div>

    </EditForm>
    </div>

    <!-- Timeline -->
    <div class="card">
        <h3>Dispute Status</h3>

        <div class="timeline">
            @foreach (var step in TimelineSteps)
            {
                <div class="timeline-item">
                    <div class="timeline-marker @(step.Completed ? "completed" : "")"></div>
                    <div class="timeline-content">
                        <div class="timeline-title">@step.Title</div>
                        <div class="timeline-date">@step.Date</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {

    [Parameter]
    public int OrderId { get; set; }    

    private DisputeModel Model = new();

    private List<IBrowserFile> UploadedFiles = new();

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(Model.Reason)
        && !string.IsNullOrWhiteSpace(Model.Details)
        && Model.Details.Length >= 50;

    private async Task HandleFilesChanged(IReadOnlyList<IBrowserFile> files)
    {
        UploadedFiles = files.Take(3).ToList();

        await Task.CompletedTask;
    }

    private void RemoveFile(IBrowserFile file)
    {
        UploadedFiles.Remove(file);
    }

    private void SubmitDispute()
    {
        Console.WriteLine("Dispute submitted");
    }

    private List<TimelineStep> TimelineSteps = new()
    {
        new()
        {
            Title = "Dispute Submitted",
            Date = "2026-05-18 12:12",
            Completed = true
        },

        new()
        {
            Title = "Evidence Verification",
            Date = "Pending",
            Completed = false
        },

        new()
        {
            Title = "Owner Response",
            Date = "Pending",
            Completed = false
        },

        new()
        {
            Title = "Final Resolution",
            Date = "Pending",
            Completed = false
        }
    };

    public class DisputeModel
    {
        public string Reason { get; set; } = "";

        [MinLength(50)]
        public string Details { get; set; } = "";
    }

    public class TimelineStep
    {
        public string Title { get; set; } = "";

        public string Date { get; set; } = "";

        public bool Completed { get; set; }
    }
}