<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Blazorise" Version="2.1.0" />
    <PackageReference Include="Blazorise.Bootstrap" Version="2.1.0" />
    <PackageReference Include="Blazorise.Bootstrap5" Version="2.1.0" />
    <PackageReference Include="Blazorise.Components" Version="2.1.0" />
    <PackageReference Include="Blazorise.Icons.FontAwesome" Version="2.1.0" />
    <PackageReference Include="Microsoft.Extensions.Http.Polly" Version="10.0.8" />
    <PackageReference Include="MudBlazor" Version="9.4.0" />
    <PackageReference Include="Polly.Extensions.Http" Version="3.0.0" />
  </ItemGroup>

</Project>
